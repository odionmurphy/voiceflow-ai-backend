# Server
PORT=4000
NODE_ENV=development

# Database (local Postgres or hosted e.g. Supabase/Neon/Render)
DATABASE_URL=postgresql://user:password@localhost:5432/voiceflow_ai

# Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Google OAuth (dashboard login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth (dashboard login)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# Google Calendar integration
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:4000/api/calendar/google/callback

# Frontend origin (for CORS)
CLIENT_ORIGIN=http://localhost:3000

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_BUSINESS=
STRIPE_TRIAL_DAYS=14

# Upstash Redis (REST) - shared rate-limit store for /api/auth/login and /register.
# Free tier at upstash.com. Leave both blank to disable rate limiting (e.g. local dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
